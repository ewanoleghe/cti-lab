# ----------------------------------------------------------------------------
# CTI-Lab Configuration Template (.env.example)
# Copy this file to .env and replace placeholders with your real values.
# Never commit .env to Git!
# ----------------------------------------------------------------------------

# -----------------------------
# API KEYS (required for most features)
# -----------------------------

# Shodan API key (free tier available)
# Get it at: https://account.shodan.io/
SHODAN_API_KEY=your_shodan_api_key_here

# Have I Been Pwned (HIBP) API key
# Paid only (no free tier for API as of 2026)
# Get it at: https://haveibeenpwned.com/API/Key
HIBP_API_KEY=your_paid_hibp_key_here

# NVD (NIST Vulnerability Database) API key
# Free - get it at: https://nvd.nist.gov/developers/request-an-api-key
NVD_API_KEY=your_nvd_api_key_here

# -----------------------------
# COMPANY / BRAND MONITORING
# -----------------------------

# Your company or organization name (used in keyword matching)
COMPANY_NAME=Your Company Name

# Primary domain to monitor (used for Shodan, mentions, etc.)
COMPANY_DOMAIN=yourcompany.com

# Keywords to detect in web/paste/mention monitoring
# One per line - add brand variations, misspellings, acronyms, etc.
KEYWORDS="
Your Company Name
yourcompany.com
yourcompany
@yourcompany.com
YourCompany
Your Co
"

# Emails to check for breaches (HIBP)
# One per line - add corporate or relevant personal emails
COMPANY_EMAILS="
info@yourcompany.com
admin@yourcompany.com
contact@yourcompany.com
support@yourcompany.com
hr@yourcompany.com
# Add more as needed
"

# Keywords specifically for paste/leak monitoring (usually same as above + emails)
PASTE_SEARCH_TERMS="
Your Company Name
yourcompany.com
yourcompany
@yourcompany.com
info@yourcompany.com
# Add more as needed
"

# -----------------------------
# Polite Web Scraping / Requests
# -----------------------------

# List of User-Agents to rotate (helps avoid blocks)
# Update browser versions occasionally
USER_AGENTS="
Mozilla/5.0 (Windows NT 10.0; Win64; x64) AppleWebKit/537.36 (KHTML, like Gecko) Chrome/124.0.0.0 Safari/537.36
Mozilla/5.0 (Macintosh; Intel Mac OS X 14_2_1) AppleWebKit/537.36 (KHTML, like Gecko) Chrome/123.0.0.0 Safari/537.36
Mozilla/5.0 (X11; Linux x86_64) AppleWebKit/537.36 (KHTML, like Gecko) Chrome/122.0.0.0 Safari/537.36
Mozilla/5.0 (Windows NT 10.0; Win64; x64; rv:126.0) Gecko/20100101 Firefox/126.0
Mozilla/5.0 (Macintosh; Intel Mac OS X 14.3) AppleWebKit/605.1.15 (KHTML, like Gecko) Version/17.3 Safari/605.1.15
"

# Domains to exclude from web/mention monitoring (safe sources)
# Comma-separated, no quotes around each item
SAFE_DOMAINS="
yourcompany.com
www.yourcompany.com
linkedin.com
facebook.com
twitter.com
x.com
instagram.com
youtube.com
zoominfo.com
rocketreach.co
hunter.io
apollo.io
"

# Leak context detection patterns (regex)
# One pattern per numbered key - add more as needed
LEAK_CONTEXT_PATTERNS_1=\b(leak|leaked|leakage|dumps?|dumped|breach|breached|paste|pastebin|psbdmp|exposed|exposure|credential|credentials|password|passwords|combo|combolist|steal|stolen|hack|hacked|hacker|database|databases|dark ?web|telegram|forum|onion)\b
LEAK_CONTEXT_PATTERNS_2=\b(ransom|ransomeware|lockbit|conti|alphv|blackcat|play|medusa)\b
# Add more if needed:
# LEAK_CONTEXT_PATTERNS_3=...

# -----------------------------
# Optional / Advanced
# -----------------------------

# Slack / Discord webhook URL for alerts (optional)
# SLACK_WEBHOOK_URL=https://hooks.slack.com/services/xxx/yyy/zzz

# Email address to send alerts to (if using SMTP)
# ALERT_EMAIL=you@example.com
